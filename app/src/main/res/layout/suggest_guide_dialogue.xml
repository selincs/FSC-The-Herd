<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/submit_a_new_guide"
        android:textColor="#1B3022"
        android:textSize="20sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/etSuggestTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_edittext_rounded"
        android:hint="@string/title_e_g_fsc_shuttle_schedule" />

    <Spinner
        android:id="@+id/spinnerCategory"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_edittext_rounded"
        android:entries="@array/guide_categories" />

    <EditText
        android:id="@+id/etSuggestDesc"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_edittext_rounded"
        android:gravity="top"
        android:hint="Tell us more about this resource..."
        android:padding="12dp" />
</LinearLayout>
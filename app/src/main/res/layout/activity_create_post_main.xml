<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#EAF1EA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include
        android:id="@+id/topToolbar"
        layout="@layout/layout_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

    <TextView
        android:id="@+id/todays_status_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Today's Status Post"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#2F442F"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="30dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

        <EditText
            android:id="@+id/post_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="What's on your mind today?"
            android:layout_margin="16dp"
            android:layout_marginBottom="12dp"
            app:layout_constraintTop_toBottomOf="@+id/todays_status_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/submit_post_button"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Post"
        android:layout_margin="16dp"
        android:backgroundTint="#2F442F"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/post_input"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/example_section_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Example Posts"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2F442F"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toBottomOf="@id/submit_post_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Example Post 1 -->
    <TextView
        android:id="@+id/example_status_post_1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Just finished a great workout today 💪 Feeling energized!"
        android:textColor="#2F442F"
        android:textSize="16sp"
        android:padding="14dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@+id/example_section_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Example Post 2 -->
    <TextView
        android:id="@+id/example_status_post_2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Coffee and coding ☕💻  best combo for a productive night."
        android:textColor="#2F442F"
        android:textSize="16sp"
        android:padding="14dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/example_status_post_1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Example Post 3 -->
    <TextView
        android:id="@+id/example_status_post_3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Beautiful weather today 🌤️ Perfect time for a walk outside."
        android:textColor="#2F442F"
        android:textSize="16sp"
        android:padding="14dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/example_status_post_2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Example Post 4 -->
    <TextView
        android:id="@+id/example_status_post_4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Taking some time today to relax and reset , don't stress yourself too much🧘‍♂️✨"
        android:textColor="#2F442F"
        android:textSize="16sp"
        android:padding="14dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/example_status_post_3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Example Post 5 -->
    <TextView
        android:id="@+id/example_status_post_5"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="So grateful for the little things in life today :) 🙏🌿"
        android:textColor="#2F442F"
        android:textSize="16sp"
        android:padding="14dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@id/example_status_post_4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>
    <LinearLayout
        android:id="@+id/footerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#2F442F"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/footerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/footer_text"
            android:textColor="#FCF5FD"
            android:textSize="12sp" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>
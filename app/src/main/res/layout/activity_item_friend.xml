<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="5dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <FrameLayout
            android:id="@+id/profilePicContainer"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/circle_background"
            android:backgroundTint="#D1D8D1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/imgProfilePic"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="8dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_account_circle_24"
                app:tint="#2F442F"
                android:contentDescription="View profile" />

            <View
                android:id="@+id/onlineStatusDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="2dp"
                android:background="@drawable/status_dot"
                android:elevation="4dp" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/friendInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            app:layout_constraintStart_toEndOf="@id/profilePicContainer"
            app:layout_constraintEnd_toStartOf="@id/actionButtons"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">


            <TextView
                android:id="@+id/tvFriendName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="15sp"
                android:textColor="@color/textPrimary"
                tools:text="Jane Doe" />

            <TextView
                android:id="@+id/tvFriendStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/textSecondary"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Just finished my exam 🎉" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/actionButtons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/btnMessage"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/icon_message_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Message friend"
                android:padding="7dp" />

            <ImageButton
                android:id="@+id/btnRemoveFriend"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_marginStart="6dp"
                android:src="@drawable/outline_person_remove_24"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/textSecondary"
                android:contentDescription="Remove friend"
                android:padding="7dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
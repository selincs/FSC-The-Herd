<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profileLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F4"
    tools:context=".ProfileActivity">

    <!-- Top bar -->
    <include
        android:id="@+id/topToolbar"
        layout="@layout/layout_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include
        android:id="@+id/includedNav"
        layout="@layout/layout_navbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- CONTENT -->
    <ScrollView
        android:id="@+id/profileScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/includedNav"
        app:layout_constraintBottom_toTopOf="@id/footerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="20dp">

            <!-- PROFILE IMAGE -->
            <FrameLayout
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:background="@drawable/circle_background"
                android:backgroundTint="#D9E2D9">

                <ImageView
                    android:id="@+id/profileImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/avatar_1"
                    android:contentDescription="@string/profile_image_desc"/>
            </FrameLayout>

            <!-- NAME (CLEAN HEADER STYLE) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp">

                <EditText
                    android:id="@+id/firstNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="First Name"
                    android:gravity="center"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/fugaz_one"
                    android:textColor="#2F442F"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/lastNameInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Last Name"
                    android:gravity="center"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/fugaz_one"
                    android:textColor="#2F442F"/>
            </LinearLayout>

            <!-- USERNAME -->
            <EditText
                android:id="@+id/usernameInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_username"
                android:textSize="14sp"
                android:textColor="#6B7D6B"
                android:textStyle="italic"
                android:layout_marginBottom="10dp"
                android:background="@android:color/transparent" />

            <!-- MAJOR + GRAD -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="18dp">

                <EditText
                    android:id="@+id/majorInput"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_major"
                    android:textSize="14sp"
                    android:textColor="#2F442F"
                    android:background="@android:color/transparent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textColor="#2F442F"
                    android:textStyle="bold"
                    android:paddingHorizontal="6dp"/>

                <EditText
                    android:id="@+id/graduationDateInput"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/profile_grad_year"
                    android:textSize="14sp"
                    android:textColor="#2F442F"
                    android:background="@android:color/transparent" />
            </LinearLayout>

            <!-- EDIT BUTTON -->
            <Button
                android:id="@+id/editProfileButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_profile"
                android:backgroundTint="#2F442F"
                android:textColor="@android:color/white"
                android:paddingHorizontal="28dp"
                android:layout_marginBottom="18dp"
                android:elevation="6dp" />

            <!-- CARD SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="18dp"
                android:layout_marginBottom="20dp"
                android:elevation="3dp">

                <!-- BIO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bio_section"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2F442F"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/bioInput"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:hint="@string/bio_hint"
                    android:gravity="top"
                    android:padding="10dp"
                    android:background="#F2F5F2"/>



                <!-- INTERESTS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/interests_section"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2F442F"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"/>


                <!-- OTHER -->
                <EditText
                    android:id="@+id/otherInterestInput"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="@string/interest_other"
                    android:padding="10dp"
                    android:layout_marginTop="10dp"
                    android:background="#F2F5F2"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Communities"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2F442F"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/emptyCommunitiesText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="This user has not joined any Topics/Communities yet!"
                    android:textColor="#757575"
                    android:visibility="gone"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/communitiesRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_ask_me_topic"/>

                <TextView
                    android:id="@+id/moreCommunitiesText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="and 3 more communities"
                    android:textSize="12sp"
                    android:textStyle="italic"
                    android:textColor="#2F442F"
                    android:visibility="gone"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="20dp"/>

            </LinearLayout>



            <!-- CARD WRAPPER (keeps everything organized like a real app UI) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="18dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:elevation="4dp">

                <!-- ASK ME ABOUT SECTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ask Me About"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2F442F"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">

                    <EditText
                        android:id="@+id/newTopicInput"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:hint="Add a topic"
                        android:padding="12dp"
                        android:background="#F2F5F2"/>

                    <Button
                        android:id="@+id/addTopicButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Add"
                        android:layout_marginStart="10dp"
                        android:backgroundTint="#2F442F"
                        android:textColor="@android:color/white"/>
                </LinearLayout>

                <!-- ASK ME RECYCLER -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/askMeRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="18dp"
                    tools:listitem="@layout/item_ask_me_topic"/>


                <!-- STATUS POSTS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_posts_section"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2F442F"
                    android:layout_marginBottom="10dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/statusPostsRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:scrollbars="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:layout_marginBottom="18dp"
                    tools:listitem="@layout/item_status_post"/>

                <!-- POST HISTORY -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Post History"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2F442F"
                    android:layout_marginBottom="10dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/postHistoryRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:scrollbars="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:layout_marginBottom="18dp"
                    tools:listitem="@layout/item_post_history"/>

                <!-- TEXT HISTORY -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Message History"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2F442F"
                    android:layout_marginBottom="10dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/textHistoryRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:scrollbars="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
    <!-- Footer -->
    <LinearLayout
        android:id="@+id/footerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="#2F442F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/footerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/footer_text"
            android:textColor="#FCF5FD"
            android:textSize="12sp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
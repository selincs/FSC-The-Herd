<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profileLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF1EA"
    tools:context=".ProfileActivity">

    <!-- Top bar -->
    <include
        android:id="@+id/topToolbar"
        layout="@layout/layout_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <include
        android:id="@+id/includedNav"
        layout="@layout/layout_navbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- PROFILE CONTENT -->
    <ScrollView
        android:id="@+id/profileScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toTopOf="@id/footerLayout"
        android:layout_marginTop="200dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Profile Picture with bigger circle around -->
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/circle_background"
                android:padding="20dp"> <!-- padding adjusts image size in circle -->

                <ImageView
                    android:id="@+id/profileImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/default_profile"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/profile_image_desc"/>

            </FrameLayout>

            <!-- Name -->
            <TextView
                android:id="@+id/nameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_name"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/fugaz_one"/>

            <!-- Username -->
            <TextView
                android:id="@+id/usernameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_username"
                android:textSize="16sp"
                android:layout_marginTop="4dp" />

            <!-- Major -->
            <TextView
                android:id="@+id/majorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_major"
                android:layout_marginTop="8dp" />

            <!-- Graduation Year -->
            <TextView
                android:id="@+id/gradYearText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_grad_year"
                android:layout_marginBottom="24dp" />

            <!-- Buttons below profile picture -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <!-- Edit Profile Button -->
                <Button
                    android:id="@+id/editProfileButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="@string/edit_profile"
                    android:backgroundTint="#2F442F"
                    android:textColor="@android:color/white"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="4dp"/>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:layout_marginTop="16dp"
                android:elevation="4dp">
            <!-- Interests Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interests_section"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Interest Checkboxes -->
            <CheckBox
                android:id="@+id/fitnessCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interest_fitness"/>

            <CheckBox
                android:id="@+id/codingCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interest_coding"/>

            <CheckBox
                android:id="@+id/musicCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interest_music"/>

            <CheckBox
                android:id="@+id/gamingCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interest_gaming"/>

            <CheckBox
                android:id="@+id/artCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interest_art"/>

            <!-- Other Interest -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/otherInterestInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="48dp"
                        android:hint="@string/interest_other"
                        android:padding="12dp"/>

                    <Button
                        android:id="@+id/saveOtherInterestButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="@string/save_button"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#2F442F"
                        android:textColor="@android:color/white"/>
                </LinearLayout>

            <!-- Bio Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bio_section"
                android:textSize="18sp"
                android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp"
                    android:gravity="top">

                    <EditText
                        android:id="@+id/bioInput"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:hint="@string/bio_hint"
                        android:gravity="top"
                        android:padding="8dp"/>

                    <Button
                        android:id="@+id/saveBioButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="@string/save_button"
                        android:layout_gravity="bottom|end"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#2F442F"
                        android:textColor="@android:color/white"/>
                </LinearLayout>


                <!-- Ask Me About Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ask Me About"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/newTopicInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Add a topic"
                        android:minHeight="48dp"
                        android:padding="12dp"/>

                    <Button
                        android:id="@+id/addTopicButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Add"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#2F442F"
                        android:textColor="@android:color/white"/>
                </LinearLayout>

                <!-- RecyclerView for topics -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/askMeRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="24dp"
                    tools:listitem="@layout/item_ask_me_topic"/>



                <!-- Status Posts Horizontal Scroll -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_posts_section"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/statusPostsRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:scrollbars="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_status_post"/>

                <!-- Post History Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Post History"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/postHistoryRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:scrollbars="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_post_history"/>

                <!-- Text History Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Text History"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/textHistoryRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:scrollbars="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_text_history"/>

        </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/footerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="#2F442F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/footerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/footer_text"
            android:textColor="#FCF5FD"
            android:textSize="12sp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
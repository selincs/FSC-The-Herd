<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_guide_template"
    android:background="#EAF1EA"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".GuideMainPageActivity">

    <!-- Top bar -->

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#2F442F"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

        <!-- Logo image on left -->
        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/logo_desc"
            android:src="@mipmap/ic_launcher" />

        <!-- Title the herd next to logo -->
        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="20dp"
            android:text="@string/toolbar_title"
            android:textColor="@android:color/white"
            android:textSize="20sp" />

        <!-- Settings button -->
        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings_desc"
            android:src="@drawable/ic_settings"
            app:tint="@android:color/white" />

        <!-- Home button -->
        <ImageButton
            android:id="@+id/homeButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/home_desc"
            android:src="@drawable/ic_home"
            app:tint="@android:color/white" />

    </androidx.appcompat.widget.Toolbar>

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/main_page_toolbar"
        android:layout_width="437dp"
        android:layout_height="117dp"
        android:layout_marginTop="64dp"
        android:background="#2F442F"
        android:backgroundTint="#2F442F"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.538"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flow_row1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:constraint_referenced_ids="profile_button,friends_button,events_button,guide_button"
        app:flow_horizontalStyle="packed"
        app:flow_horizontalGap="10dp"
        app:layout_constraintEnd_toEndOf="@+id/main_page_toolbar"
        app:layout_constraintStart_toStartOf="@+id/main_page_toolbar"
        app:layout_constraintTop_toTopOf="@+id/main_page_toolbar" />

    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flow_row2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:constraint_referenced_ids="community_button,interests_button,motivation_button"
        app:flow_horizontalStyle="packed"
        app:flow_horizontalGap="10dp"
        app:layout_constraintEnd_toEndOf="@+id/main_page_toolbar"
        app:layout_constraintStart_toStartOf="@+id/main_page_toolbar"
        app:layout_constraintTop_toBottomOf="@id/flow_row1" />

    <Button style="@style/PillButton" android:id="@+id/profile_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" />
    <Button style="@style/PillButton" android:id="@+id/friends_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Friends" />
    <Button style="@style/PillButton" android:id="@+id/events_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Events" />
    <Button style="@style/PillButton" android:id="@+id/guide_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Guides" />
    <Button style="@style/PillButton" android:id="@+id/community_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Community" />
    <Button style="@style/PillButton" android:id="@+id/interests_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Topics" />
    <Button style="@style/PillButton" android:id="@+id/motivation_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Motivation" />

    <!--Body-->

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/footerLayout"
        app:layout_constraintTop_toBottomOf="@id/main_page_toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Category Header -->
            <TextView
                android:id="@+id/tvCampusHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#9BB194"
                android:padding="8dp"
                android:layout_marginTop="20dp"
                android:text="@string/campus_services"
                android:textColor="#000000"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCampusServices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/guide_card"
                tools:itemCount="4" />

            <TextView
                android:id="@+id/tvAcademicHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#9BB194"
                android:padding="8dp"
                android:layout_marginTop="20dp"
                android:text="@string/academic_services"
                android:textColor="#000000"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvAcademicServices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/guide_card"
                tools:itemCount="4" />

            <TextView
                android:id="@+id/tvStudentLifeHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#9BB194"
                android:padding="8dp"
                android:layout_marginTop="20dp"
                android:text="@string/student_life"
                android:textColor="#000000"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvStudentLife"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/guide_card"
                tools:itemCount="4" />

            <TextView
                android:id="@+id/tvOtherHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#9BB194"
                android:padding="8dp"
                android:layout_marginTop="20dp"
                android:text="@string/other"
                android:textColor="#000000"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOther"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="2"
                tools:listitem="@layout/guide_card"
                tools:itemCount="4" />

        </LinearLayout>
    </ScrollView>

    <!--footer-->

    <LinearLayout
        android:id="@+id/footerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#2F442F"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/footerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/footer_text"
            android:textColor="#FCF5FD"
            android:textSize="12sp" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>

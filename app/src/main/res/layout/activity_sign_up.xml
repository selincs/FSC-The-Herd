<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/signUpLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF1EA"
    tools:context=".SignUpActivity">

    <!-- Top bar -->
    <include
        android:id="@+id/topToolbar"
        layout="@layout/layout_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Footer -->
    <include
        android:id="@+id/footerLayout"
        layout="@layout/layout_footer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Signup form -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/topToolbar"
        app:layout_constraintBottom_toTopOf="@id/footerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:fillViewport="true"
        android:paddingBottom="60dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- title -->
            <TextView
                android:id="@+id/signUpTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/sign_up_title"
                android:textSize="32sp"
                android:fontFamily="@font/fugaz_one"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:textColor="#2F442F"/>

            <!-- Logo -->
            <ImageView
                android:id="@+id/signUpLogo"
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="@string/app_logo_desc"
                android:layout_marginBottom="24dp"/>

            <!-- First name -->
            <EditText
                android:id="@+id/firstNameField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:paddingVertical="12dp"
                android:hint="@string/first_name"
                android:inputType="textPersonName"
                android:autofillHints="givenName"
                android:layout_marginBottom="12dp"/>

            <!-- Last name -->
            <EditText
                android:id="@+id/lastNameField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:paddingVertical="12dp"
                android:hint="@string/last_name"
                android:inputType="textPersonName"
                android:autofillHints="familyName"
                android:layout_marginBottom="12dp"/>

            <!-- FSC email input with fixed domain -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <!-- Editable username part -->
                <EditText
                    android:id="@+id/emailUsernameField"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Enter your FSC email"
                    android:inputType="textEmailAddress"
                    android:paddingHorizontal="8dp"/>

                <!-- Fixed domain -->
                <TextView
                    android:id="@+id/emailDomain"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="\@farmingdale.edu"
                    android:gravity="center_vertical"
                    android:paddingStart="4dp"
                    android:textColor="#000"/>
            </LinearLayout>

            <!-- Graduation section with title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:gravity="center_horizontal">

                <!-- Title -->
                <TextView
                    android:id="@+id/graduationTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Expected  Graduation  Date"
                    android:textSize="16sp"
                    android:textColor="#2F442F"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"/>

                <!-- Spinners side by side -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2"
                    android:gravity="center_vertical">

                    <!-- Season Spinner -->
                    <Spinner
                        android:id="@+id/graduationSeasonSpinner"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:spinnerMode="dropdown"
                        android:padding="8dp"
                        android:layout_marginEnd="8dp"/>

                    <!-- Year Spinner -->
                    <Spinner
                        android:id="@+id/graduationYearSpinner"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:spinnerMode="dropdown"
                        android:padding="8dp"
                        android:layout_marginStart="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Password -->
            <EditText
                android:id="@+id/passwordField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:paddingVertical="12dp"
                android:hint="@string/password"
                android:inputType="textPassword"
                android:autofillHints="password"
                android:layout_marginBottom="12dp"/>

            <!-- Confirm password -->
            <EditText
                android:id="@+id/confirmPasswordField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:paddingVertical="12dp"
                android:hint="@string/confirm_password"
                android:inputType="textPassword"
                android:autofillHints="password"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/passwordRequirementsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp"
                android:padding="8dp"
                android:background="#10000000">

                <TextView
                    android:id="@+id/reqLength"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• At least 8 characters"
                    android:textSize="12sp"
                    android:textColor="#888888" />

                <TextView
                    android:id="@+id/reqUpper"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• 1 uppercase letter"
                    android:textSize="12sp"
                    android:textColor="#888888" />

                <TextView
                    android:id="@+id/reqLower"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• 1 lowercase letter"
                    android:textSize="12sp"
                    android:textColor="#888888" />

                <TextView
                    android:id="@+id/reqDigit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• 1 number"
                    android:textSize="12sp"
                    android:textColor="#888888" />

                <TextView
                    android:id="@+id/reqMatch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• Passwords match"
                    android:textSize="12sp"
                    android:textColor="#888888" />
            </LinearLayout>

            <!-- Validation message -->
            <TextView
                android:id="@+id/validationMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF0000"
                android:text=""
                android:layout_marginBottom="24dp"/>

            <!-- Create account btn -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/createAccountButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="@string/create_account"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2F442F"
                android:elevation="10dp"/>

            <!-- Already have account -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account?"
                android:layout_marginBottom="8dp"/>


            <!-- Login btn -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/loginButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/login"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2F442F"/>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
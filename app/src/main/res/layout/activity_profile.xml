<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profileLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EAF1EA"
    tools:context=".ProfileActivity">

    <!-- Top bar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/topToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#2F442F"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

        <ImageView
            android:id="@+id/logoImage"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/logo_desc"
            android:layout_marginStart="8dp"
            android:layout_gravity="start|center_vertical" />

        <TextView
            android:id="@+id/guides_main_page_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/toolbar_title"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:layout_marginStart="8dp"
            android:layout_gravity="start|center_vertical" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/settingsButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_settings"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/settings_desc"
            app:tint="@android:color/white"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="8dp"/>

        <ImageButton
            android:id="@+id/homeButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_home"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/home_desc"
            app:tint="@android:color/white"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="8dp"/>
    </androidx.appcompat.widget.Toolbar>

    <!-- Body -->


    <androidx.appcompat.widget.Toolbar
        android:id="@+id/main_page_toolbar"
        android:layout_width="437dp"
        android:layout_height="117dp"
        android:layout_marginTop="64dp"
        android:background="#2F442F"
        android:backgroundTint="#2F442F"
        android:minHeight="?attr/actionBarSize"
        android:theme="?attr/actionBarTheme"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.538"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flow_row1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:constraint_referenced_ids="profile_button,friends_button,events_button,guide_button"
        app:flow_horizontalStyle="packed"
        app:flow_horizontalGap="10dp"
        app:layout_constraintEnd_toEndOf="@+id/main_page_toolbar"
        app:layout_constraintStart_toStartOf="@+id/main_page_toolbar"
        app:layout_constraintTop_toTopOf="@+id/main_page_toolbar" />

    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flow_row2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        app:constraint_referenced_ids="community_button,interests_button,motivation_button"
        app:flow_horizontalStyle="packed"
        app:flow_horizontalGap="10dp"
        app:layout_constraintEnd_toEndOf="@+id/main_page_toolbar"
        app:layout_constraintStart_toStartOf="@+id/main_page_toolbar"
        app:layout_constraintTop_toBottomOf="@id/flow_row1" />

    <Button style="@style/PillButton" android:id="@+id/profile_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profile" />
    <Button style="@style/PillButton" android:id="@+id/friends_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Friends" />
    <Button style="@style/PillButton" android:id="@+id/events_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Events" />
    <Button style="@style/PillButton" android:id="@+id/guide_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Guides" />
    <Button style="@style/PillButton" android:id="@+id/community_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Community" />
    <Button style="@style/PillButton" android:id="@+id/interests_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Interests" />
    <Button style="@style/PillButton" android:id="@+id/motivation_button"
        android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Motivation" />

    <!-- PROFILE CONTENT -->
    <ScrollView
        android:id="@+id/profileScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/main_page_toolbar"
        app:layout_constraintBottom_toTopOf="@id/footerLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <!-- Profile Picture with bigger circle around -->
            <FrameLayout
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/circle_background"
                android:padding="20dp"> <!-- padding adjusts image size in circle -->

                <ImageView
                    android:id="@+id/profileImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/default_profile"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/profile_image_desc"/>

            </FrameLayout>

            <!-- Name -->
            <EditText
                android:id="@+id/firstNameInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="First Name"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/fugaz_one"/>

            <EditText
                android:id="@+id/lastNameInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:hint="Last Name"
                android:gravity="center"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/fugaz_one"/>

            <!-- Username -->
            <EditText
                android:id="@+id/usernameInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_username"
                android:textSize="16sp"
                android:layout_marginTop="4dp" />

            <!-- Major -->
            <EditText
                android:id="@+id/majorInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_major"
                android:layout_marginTop="8dp" />

            <!-- Graduation Year -->
            <EditText
                android:id="@+id/gradYearInput"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_grad_year"
                android:layout_marginBottom="24dp" />

            <!-- Buttons below profile picture -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <!-- Edit Profile Button -->
                <Button
                    android:id="@+id/editProfileButton"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:text="@string/edit_profile"
                    android:backgroundTint="#2F442F"
                    android:textColor="@android:color/white"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginEnd="8dp"
                    android:elevation="4dp"/>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:layout_marginTop="16dp"
                android:elevation="4dp">
            <!-- Interests Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interests_section"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/selectedInterestsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Selected Interests:"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

            <!-- Interest Checkboxes -->
            <CheckBox
                android:id="@+id/fitnessCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interest_fitness"/>

            <CheckBox
                android:id="@+id/codingCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interest_coding"/>

            <CheckBox
                android:id="@+id/musicCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interest_music"/>

            <CheckBox
                android:id="@+id/gamingCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interest_gaming"/>

            <CheckBox
                android:id="@+id/artCheck"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/interest_art"/>

            <!-- Other Interest -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/otherInterestInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:minHeight="48dp"
                        android:hint="@string/interest_other"
                        android:padding="12dp"/>
                </LinearLayout>

            <!-- Bio Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bio_section"
                android:textSize="18sp"
                android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp"
                    android:gravity="top">

                    <EditText
                        android:id="@+id/bioInput"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:hint="@string/bio_hint"
                        android:gravity="top"
                        android:padding="8dp"/>

                </LinearLayout>


                <!-- Ask Me About Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ask Me About"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/newTopicInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Add a topic"
                        android:minHeight="48dp"
                        android:padding="12dp"/>

                    <Button
                        android:id="@+id/addTopicButton"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Add"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="#2F442F"
                        android:textColor="@android:color/white"/>
                </LinearLayout>

                <!-- RecyclerView for topics -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/askMeRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="24dp"
                    tools:listitem="@layout/item_ask_me_topic"/>



                <!-- Status Posts Horizontal Scroll -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_posts_section"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/statusPostsRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:scrollbars="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_status_post"/>

                <!-- Post History Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Post History"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/postHistoryRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:scrollbars="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_post_history"/>

                <!-- Text History Section -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Text History"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/textHistoryRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:clipToPadding="false"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:scrollbars="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    tools:listitem="@layout/item_text_history"/>

        </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/footerLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="#2F442F"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/footerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/footer_text"
            android:textColor="#FCF5FD"
            android:textSize="12sp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
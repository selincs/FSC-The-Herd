<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <ImageView
                android:id="@+id/ivGuideIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="@string/WiFi_symbol"
                android:src="@drawable/ic_wifi"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#1B3022" />

            <TextView
                android:id="@+id/tvGuideTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/ivGuideIcon"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Wi-Fi &amp; IT Support" />

            <TextView
                android:id="@+id/tvGuideDesc"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#555555"
                android:textSize="11sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/tvGuideTitle"
                app:layout_constraintTop_toBottomOf="@id/tvGuideTitle"
                tools:text="Wi-Fi &amp; IT support and training technology support." />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/tvStatusBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_badge_verified"
        android:elevation="6dp"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:textColor="#1B3022"
        android:textSize="11sp"
        android:textStyle="bold"
        android:translationY="-8dp"
        app:layout_constraintEnd_toEndOf="@id/cardContainer"
        app:layout_constraintTop_toTopOf="@id/cardContainer"
        tools:text="✔ Verified" />

</androidx.constraintlayout.widget.ConstraintLayout>